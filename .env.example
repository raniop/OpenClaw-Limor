# ═══════════════════════════════════════════════════════════
# Bot Configuration — Required
# ═══════════════════════════════════════════════════════════

# Assistant name (Hebrew) — what your AI assistant will be called
BOT_NAME=לימור
# Assistant name (English) — used in logs and technical references
BOT_NAME_EN=Limor
# Soul file to load from souls/ directory (without .json extension)
SOUL_NAME=limor

# ═══════════════════════════════════════════════════════════
# Owner Configuration — Required
# Primary source of truth is workspace/owner.json (created by setup wizard).
# These env vars are fallbacks if owner.json doesn't exist.
# ═══════════════════════════════════════════════════════════

# Your first name (Hebrew)
OWNER_NAME=
# Your WhatsApp chat ID (get this from first run logs)
OWNER_CHAT_ID=
# Your phone number (Israeli format: 972XXXXXXXXX)
OWNER_PHONE=
# Your email address
OWNER_EMAIL=

# Owner gender, family, integrations, and SMS watched senders are configured
# in workspace/owner.json. Run `npm run setup` to generate it interactively.

# ═══════════════════════════════════════════════════════════
# AI — Required
# ═══════════════════════════════════════════════════════════

# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (optional — used for voice transcription)
OPENAI_API_KEY=

# ═══════════════════════════════════════════════════════════
# Google Calendar — Optional (for calendar features)
# ═══════════════════════════════════════════════════════════

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Apple Calendar name (macOS) — defaults to "Home"
# APPLE_CALENDAR_NAME=Home

# ═══════════════════════════════════════════════════════════
# Email (SMTP) — Optional (for email features)
# ═══════════════════════════════════════════════════════════

SMTP_EMAIL=
SMTP_PASSWORD=

# ═══════════════════════════════════════════════════════════
# iCloud IMAP — Optional (for reading incoming email)
# ═══════════════════════════════════════════════════════════

ICLOUD_IMAP_EMAIL=
ICLOUD_IMAP_PASSWORD=

# ═══════════════════════════════════════════════════════════
# CRM — Optional (for insurance CRM features)
# ═══════════════════════════════════════════════════════════

CRM_API_URL=
CRM_USERNAME=
CRM_PASSWORD=

# ═══════════════════════════════════════════════════════════
# Har HaBituach — Optional (Israeli insurance policy scraper)
# ═══════════════════════════════════════════════════════════

HARB_ID_NUMBER=
HARB_PASSWORD=

# ═══════════════════════════════════════════════════════════
# Web Search — Optional (for internet search)
# ═══════════════════════════════════════════════════════════

# Brave Search API (get from brave.com/search/api — free tier)
BRAVE_SEARCH_API_KEY=
# RapidAPI (for flight/hotel search)
RAPIDAPI_KEY=

# ═══════════════════════════════════════════════════════════
# Smart Home (Control4) — Optional
# ═══════════════════════════════════════════════════════════

CONTROL4_DIRECTOR_IP=
CONTROL4_USERNAME=
CONTROL4_PASSWORD=

# ═══════════════════════════════════════════════════════════
# Gett Taxi — Optional
# ═══════════════════════════════════════════════════════════

GETT_CLIENT_ID=
GETT_CLIENT_SECRET=
GETT_BUSINESS_ID=

# ═══════════════════════════════════════════════════════════
# Telegram — Optional (for reading Telegram groups/channels)
# ═══════════════════════════════════════════════════════════

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# ═══════════════════════════════════════════════════════════
# Office PC (remote login) — Optional
# ═══════════════════════════════════════════════════════════

OFFICE_PC_HOST=
OFFICE_PC_USER=
OFFICE_PC_PASS=
OFFICE_PC_KEY_PATH=

# ═══════════════════════════════════════════════════════════
# Health Webhook — Optional (iOS Shortcut → /health-data)
# ═══════════════════════════════════════════════════════════

HEALTH_WEBHOOK_TOKEN=
HEALTH_WEBHOOK_PORT=3848
# Daily calorie goal for health tool (0 = disabled)
HEALTH_DAILY_CALORIE_GOAL=0

# ═══════════════════════════════════════════════════════════
# Advanced Settings
# ═══════════════════════════════════════════════════════════

# Max conversation history messages (default: 100)
MAX_HISTORY=100
# Enable detailed AI trace logging (true/false)
DEBUG_BRAIN_TRACE=false
# Custom state directory (default: workspace/state)
# LIMOR_STATE_DIR=
