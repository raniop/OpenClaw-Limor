# ═══════════════════════════════════════════════════════════
# Bot Configuration — Required
# ═══════════════════════════════════════════════════════════

# Bot name (Hebrew) — the name your assistant will use
BOT_NAME=לימור
# Bot name (English) — used in logs and technical references
BOT_NAME_EN=Limor
# Soul file to load from souls/ directory (without .json extension)
SOUL_NAME=limor

# ═══════════════════════════════════════════════════════════
# Owner Configuration — Required
# ═══════════════════════════════════════════════════════════

# Your name (Hebrew)
OWNER_NAME=רני
# Your WhatsApp chat ID (get this from first run logs)
OWNER_CHAT_ID=
# Your phone number (Israeli format: 972XXXXXXXXX)
OWNER_PHONE=
# Your email address
OWNER_EMAIL=

# ═══════════════════════════════════════════════════════════
# AI — Required
# ═══════════════════════════════════════════════════════════

# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (optional — used for voice transcription)
OPENAI_API_KEY=

# ═══════════════════════════════════════════════════════════
# Google Calendar — Optional (for calendar features)
# ═══════════════════════════════════════════════════════════

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ═══════════════════════════════════════════════════════════
# Email (SMTP) — Optional (for email features)
# ═══════════════════════════════════════════════════════════

SMTP_EMAIL=
SMTP_PASSWORD=

# ═══════════════════════════════════════════════════════════
# CRM — Optional (for insurance CRM features)
# ═══════════════════════════════════════════════════════════

CRM_API_URL=
CRM_USERNAME=
CRM_PASSWORD=

# ═══════════════════════════════════════════════════════════
# Web Search — Optional (for internet search)
# ═══════════════════════════════════════════════════════════

# Brave Search API (get from brave.com/search/api — free tier)
BRAVE_SEARCH_API_KEY=
# RapidAPI (for flight/hotel search)
RAPIDAPI_KEY=

# ═══════════════════════════════════════════════════════════
# Smart Home (Control4) — Optional
# ═══════════════════════════════════════════════════════════

CONTROL4_DIRECTOR_IP=
CONTROL4_USERNAME=
CONTROL4_PASSWORD=

# ═══════════════════════════════════════════════════════════
# Gett Taxi — Optional
# ═══════════════════════════════════════════════════════════

GETT_CLIENT_ID=
GETT_CLIENT_SECRET=
GETT_BUSINESS_ID=

# ═══════════════════════════════════════════════════════════
# Advanced Settings
# ═══════════════════════════════════════════════════════════

# Max conversation history messages (default: 100)
MAX_HISTORY=100
# Enable detailed AI trace logging (true/false)
DEBUG_BRAIN_TRACE=false
# Custom state directory (default: workspace/state)
# LIMOR_STATE_DIR=
