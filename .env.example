# === Required ===
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === WhatsApp Owner ===
# After first run, the bot prints each sender's chatId in logs.
# Find yours and paste it here so the bot recognizes you as the owner.
OWNER_CHAT_ID=

# === Owner Details (auto-filled in restaurant bookings) ===
OWNER_NAME=
OWNER_PHONE=
OWNER_EMAIL=

# === Google Calendar (optional) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# === Email / Calendar Invites (optional, Gmail SMTP) ===
SMTP_EMAIL=
SMTP_PASSWORD=

# === Flight & Hotel Search (optional, RapidAPI) ===
RAPIDAPI_KEY=

# === CRM Integration (optional) ===
CRM_API_URL=
CRM_USERNAME=
CRM_PASSWORD=

# === Bot Config (optional) ===
SOUL_NAME=limor
MAX_HISTORY=20
